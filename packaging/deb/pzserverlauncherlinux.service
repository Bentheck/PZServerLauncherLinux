[Unit]
Description=PZServerLauncherLinux
After=network.target

[Service]
Type=simple
User=pzlauncher
Group=pzlauncher
EnvironmentFile=-/etc/default/pzserverlauncherlinux
ExecStart=/opt/pzserverlauncher/.venv/bin/pzserverlauncherlinux
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
